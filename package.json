  "repository": {
    "type": "git",
    "url": "https://github.com/genomicx/mashx.git"
  },
  "bugs": {
    "url": "https://github.com/genomicx/mashx/issues"
  },
  "keywords": [
    "mashx",
    "mash",
    "bioinformatics",
    "genomics",
    "webassembly"
  ],
  "scripts": {
    "dev": "vite",
