{
  "name": "mashx",
  "version": "0.1.0",
  "description": "Browser-based Mash distance tool for querying preloaded or user-supplied sketch databases",
  "type": "module",
  "license": "GPL-3.0-only",
  "author": "Nabil-Fareed Alikhan <nabil@happykhan.com> (https://www.happykhan.com)",
